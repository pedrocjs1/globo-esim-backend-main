NODE_ENV=development
PORT=4000

# Base de datos
# SQLite (desarrollo): DATABASE_URL="file:./dev.db"
# PostgreSQL (producción): DATABASE_URL="postgresql://user:password@host:5432/dbname"
DATABASE_URL="file:./dev.db"

# Airalo API
AIRALO_CLIENT_ID=your_client_id
AIRALO_CLIENT_SECRET=your_client_secret
AIRALO_API_BASE=https://partners-api.airalo.com
AIRALO_BRAND_NAME="Globo eSIM"

# CORS — orígenes permitidos (separados por coma)
ALLOWED_ORIGINS=http://localhost:3000,https://tudominio.com

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=tu@email.com
SMTP_PASS=tu_app_password
SMTP_FROM=tu@email.com

# Admin (clave para GET /api/orders — dejar vacío para deshabilitar)
ADMIN_API_KEY=

# Logs
LOG_LEVEL=info
